{
  "$schema": ".cmake/Project.schema.json",
  "Project": {
    "Name": "HelloSDL",
    "ID": "dev.diyou.sdltemplate",
    "Version": "0.0.1",
    "Description": "A multi-platform template for SDL3 apps",
    "URL": "https://wiki.libsdl.org/SDL3/FrontPage"
  },
  "Depends": {
    "sdl3": {
      "description": "Simple DirectMedia Layer",
      "type": "archive",
      "url": "https://github.com/libsdl-org/SDL/releases/download/release-3.4.2/SDL3-3.4.2.tar.gz",
      "sha256": "sha256:ef39a2e3f9a8a78296c40da701967dd1b0d0d6e267e483863ce70f8a03b4050c",
      "emscripten-port": "sdl3"
    },
    "dawn":{
      "description": "Dawn, a WebGPU implementation",
      "type": "git",
      "url": "https://dawn.googlesource.com/dawn",
      "tag": "chromium/7737",
      "submodules": [
        "third_party/khronos",
        "third_party/jinja2",
        "third_party/abseil-cpp",
        "third_party/googletest",
        "third_party/spirv-headers",
        "third_party/spirv-tools",
        "third_party/glslang",
        "third_party/vulkan-headers",
        "third_party/vulkan-utility-libraries",
        "third_party/protobuf",
        "third_party/libprotobuf-mutator"
      ],
      "config": "CMake/dawn.cmake"
    }
  }
}
